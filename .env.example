# ─────────────────────────────────────────────────────────────
# Анализатор закупок (procurement price-check) — пример конфигурации.
# Локально:  cp .env.example backend/.env   и заполнить.
# На сервере (Docker/systemd):  cp .env.example .env   в корне репозитория.
# Ничего не хардкодим в коде — все значения здесь.
# ─────────────────────────────────────────────────────────────

# === LLM (локальный OVMS / Qwen3, OpenAI-совместимый API) ===
# OVMS 2025.x: путь именно /v3 (не /v1). Авторизации нет — ключ-заглушка.
LLM_BASE_URL=http://10.99.99.201:8000/v3
LLM_MODEL=OpenVINO/Qwen3-14B-int8-ov
LLM_API_KEY=not-needed
LLM_TIMEOUT=300

# === Поиск цен: mock | serper | gemini | dataforseo ===
# mock   — фиктивные данные, весь пайплайн без внешних API (LLM всё равно нужен).
# serper — реальная органика google.kz (нужен ключ serper.dev) + crawl4ai для цены.
# gemini — Gemini 3.1 flash-lite с Google Search grounding: цена+ссылка одним дешёвым
#          вызовом, без crawl4ai (нужен GEMINI_API_KEY ниже).
SEARCH_PROVIDER=gemini
SERPER_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# === Gemini (Google AI Studio) ===
# Роли: (1) провайдер grounding-поиска цен; (2) резервная LLM, когда локальный
# OVMS недоступен (авто-переключение в llm.py). Ключ — из aistudio.google.com.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Геолокация и язык поиска
SEARCH_GL=kz
SEARCH_HL=ru

# Казахстанские площадки (через запятую) — используются как site:-фильтры
MARKETPLACES=satu.kz,technodom.kz,sulpak.kz,mechta.kz,alser.kz,kaspi.kz

# Сколько цен максимум тянуть на одну позицию
MAX_PRICES_PER_ITEM=5

# Порог уверенности матчинга: ниже — позиция уходит на ручную проверку
MATCH_CONFIDENCE_MIN=0.6

# ─────────────────────────────────────────────────────────────
# === Деплой на портал ai.knus.edu.kz (слаг /agents/procurement) ===
# ─────────────────────────────────────────────────────────────

# Префикс под-пути на портале. Нужен FastAPI для корректных URL за reverse-proxy.
# Должен совпадать с VITE_BASE/VITE_API_BASE сборки фронта и с location в nginx/Caddy.
# Локально — оставить пустым.
ROOT_PATH=/agents/procurement

# Аргументы сборки фронтенда (Docker берёт их из этих же имён). Слаг = procurement.
VITE_BASE=/agents/procurement/
VITE_API_BASE=/agents/procurement

# Имя внешней docker-сети платформы (где Caddy и web). Для docker-compose.
PLATFORM_NETWORK=platform

# Адрес прослушивания для systemd-варианта (uvicorn --host ${BIND_HOST}):
#   127.0.0.1               — nginx на том же хосте, что и сервис;
#   внутренний IP web-сервера — nginx на отдельном сервере (+ фаервол на 8080).
BIND_HOST=127.0.0.1

# CORS: за nginx/Caddy (same-origin) НЕ нужен. Заполнять, только если фронт
# ходит с другого домена (через запятую).
# CORS_ORIGINS=https://ai.knus.edu.kz

# ─────────────────────────────────────────────────────────────
# === База знаний закупок (Этап 1): PostgreSQL 16 + pgvector ===
# ─────────────────────────────────────────────────────────────
# Отдельный контейнер procurement-db (см. docker-compose). Пусто — база знаний
# выключена (агент работает только с рыночным поиском), для локальной разработки.
#
# ВАЖНО: пароль в DATABASE_URL должен СОВПАДАТЬ с POSTGRES_PASSWORD ниже.
POSTGRES_USER=procurement
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=procurement
DATABASE_URL=postgresql://procurement:change-me-strong-password@procurement-db:5432/procurement

# Эмбеддинги для семантического поиска аналогов (Ollama на .202).
EMBEDDING_URL=http://10.99.99.202:11434/api/embeddings
EMBEDDING_MODEL=snowflake-arctic-embed2

# Период сравнения цен по умолчанию (мес). Переопределяется в UI на каждый анализ.
DEFAULT_PRICE_PERIOD_MONTHS=6

# Роли (по email платформы). admin — по X-Is-Admin/группе или из списка ниже.
# ADMIN_EMAILS=boss@knus.edu.kz
# MANAGER_EMAILS=manager1@knus.edu.kz,manager2@knus.edu.kz
